<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="@color/background_dark">

    <TextView
        android:id="@+id/emergencyDashboard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Emergency Dashboard"
        android:textColor="@color/text_primary"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginTop="40dp"/>
    <TextView
        android:id="@+id/tvWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welcome"
        android:textColor="@color/text_secondary"
        android:textSize="17sp"
        android:textStyle="bold"
        android:layout_marginBottom="40dp"
        android:layout_marginTop="10dp"/>

    <Button
        android:id="@+id/btnHistory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:backgroundTint="@color/primary_blue"
        android:elevation="4dp"
        android:text="📜 View History"
        android:textSize="18sp"
        app:cornerRadius="28dp" />

    <Button
        android:id="@+id/btnContacts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="50dp"
        android:backgroundTint="#9567C3EF"
        android:elevation="4dp"
        android:text="📇 Manage Contacts"
        android:textSize="18sp"
        app:cornerRadius="28dp" />

    <Button
        android:id="@+id/btnAlert"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#D96666"
        android:elevation="4dp"
        android:text="🚑 Alert Button"
        android:textSize="18sp"
        app:cornerRadius="28dp" />

    <Button
        android:id="@+id/btnTrigger"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="60dp"
        android:backgroundTint="@color/button_alert"
        android:elevation="4dp"
        android:text="🚨 SOS"
        android:textStyle="bold"
        android:textSize="18sp"
        app:cornerRadius="28dp" />

    <Button
        android:id="@+id/btnQuit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/button_dark"
        android:elevation="4dp"
        android:text="Quit"
        android:textSize="17sp"
        app:cornerRadius="28dp" />

</LinearLayout>